{
  "name": "code-horse-monorepo",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "web:dev": "bun --filter code-horse dev",
    "web:build": "bun --filter code-horse build",
    "web:start": "bun --filter code-horse start",
    "cli:build": "bun --filter codehorse-cli build",
    "cli:start": "bun --filter codehorse-cli start",
    "lint": "bun --filter code-horse lint",
    "typecheck": "tsc --noEmit --project packages/web/tsconfig.json && tsc --noEmit --project packages/cli/tsconfig.json",
    "test": "bun --filter code-horse test"
  },
  "devDependencies": {
    "code-horse": "workspace:*",
    "codehorse-cli": "workspace:*"
  }
}
